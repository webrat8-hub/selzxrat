<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F5"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:padding="8dp"
        android:elevation="2dp">

        <Spinner
            android:id="@+id/spCommandType"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnSendCommand"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Send"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnBroadcastCommand"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="All"
            android:backgroundTint="#FFB6C1"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <EditText
        android:id="@+id/etPayload"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Payload (optional)"
        android:background="@android:color/white"
        android:padding="8dp"
        android:layout_marginTop="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Command History"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FF69B4"
        android:layout_marginTop="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCommands"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp" />

</LinearLayout>